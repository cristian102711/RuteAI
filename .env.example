# ============================================================
#  RouteAI — Variables de Entorno Requeridas
#  Copia este archivo como ".env.local" y rellena los valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Disponibles en: Supabase Dashboard → Project Settings → API

# URL pública del proyecto (seguro exponer en frontend)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon (seguro exponer en frontend, RLS la protege)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Clave service_role — ⚠️ NUNCA exponer en frontend
# Solo para Server Actions y operaciones admin del servidor
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ── Base de Datos (Prisma) ────────────────────────────────────
# Disponible en: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Usar la string con ?pgbouncer=true para serverless

DATABASE_URL=postgresql://postgres:[PASSWORD]@db.tu-proyecto.supabase.co:5432/postgres

# ── Google Maps (Próxima integración) ────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
# Habilitar: Maps JavaScript API + Directions API + Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Twilio (Notificaciones SMS) ───────────────────────────────
# Disponible en: console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
