# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Monorepo: node_modules en todos los packages ──────────────────
**/node_modules
/.pnp
.pnp.*

# ── Turborepo cache ───────────────────────────────────────────────
.turbo

# ── Next.js ───────────────────────────────────────────────────────
apps/web/.next/
apps/web/out/
*.tsbuildinfo

# ── Build outputs ─────────────────────────────────────────────────
**/dist
/build

# ── Prisma generated client ───────────────────────────────────────
**/generated/prisma

# ── Environment variables ─────────────────────────────────────────
.env
.env.local
.env*.local
!.env.example
# Permitir .env.example en cada package (documentación)
!packages/**/.env.example
!apps/**/.env.example

# ── Vercel ────────────────────────────────────────────────────────
.vercel

# ── Misc ──────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/coverage

